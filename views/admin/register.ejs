<%- include('../partials/head', { title: 'Register shipment — Pixel Wave Admin' }) %>
<body class="admin">
<header class="site-header"><a href="/" class="logo"><span class="logo-mark"></span>PIXEL WAVE <em>LOGISTICS</em></a></header>
<main>
  <%- include('nav', { active: 'register' }) %>
  <h1 style="font-size:32px;">Register a shipment</h1>
  <p class="lede">A tracking number is generated automatically on submit. If a receiver email is provided, they'll get a notification on every status update.</p>

  <div class="panel">
    <form method="post" action="/admin/register">
      <div class="form-grid">
        <div class="field"><label>Sender name</label><input required name="sender_name" placeholder="Jordan Ma"></div>
        <div class="field"><label>Sender email</label><input type="email" name="sender_email" placeholder="jordan@example.com"></div>
        <div class="field"><label>Receiver name</label><input required name="receiver_name" placeholder="Alicia Ford"></div>
        <div class="field"><label>Receiver email</label><input type="email" name="receiver_email" placeholder="alicia@example.com"></div>
        <div class="field"><label>Origin city</label><input required name="origin" placeholder="Rotterdam, NL"></div>
        <div class="field"><label>Destination city</label><input required name="destination" placeholder="Austin, TX"></div>
        <div class="field"><label>Weight (kg)</label><input type="number" step="0.1" min="0" name="weight" placeholder="4.2"></div>
        <div class="field">
          <label>Service level</label>
          <select name="service"><option>Standard</option><option>Express</option><option>Freight</option></select>
        </div>
        <div class="field"><label>Estimated delivery</label><input type="date" name="eta"></div>
        <div class="field"><label>Notes (optional)</label><input name="notes" placeholder="Fragile — handle with care"></div>
      </div>
      <div class="form-actions"><button class="btn" type="submit">Register package</button></div>
    </form>
    <% if (created) { %>
      <div class="success-note" style="display:block;">Shipment registered &mdash; tracking number <b><%= created %></b>. Share this with the customer.</div>
    <% } %>
  </div>
</main>
</body>
</html>
