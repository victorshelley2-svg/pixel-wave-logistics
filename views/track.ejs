<%- include('partials/head', { title: tn ? tn + ' — Pixel Wave Logistics' : 'Track — Pixel Wave Logistics' }) %>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<%- include('partials/header', { active: 'track' }) %>

<div class="hero">
  <div class="eyebrow">LIVE SHIPMENT SIGNAL</div>
  <h1>Track your shipment.</h1>
  <p class="lede">Enter your tracking number to see its current status and full history.</p>
  <div class="signal-track"></div>

  <form class="form-row" action="/track" method="get">
    <input type="text" name="tn" placeholder="e.g. PW-4821-KTQ7" value="<%= tn || '' %>" autocomplete="off">
    <button class="btn" type="submit">Track</button>
  </form>
</div>

<% if (notFound) { %>
  <div class="not-found">NO SIGNAL &mdash; we couldn't find a shipment matching <strong><%= tn %></strong>. Check the tracking number and try again.</div>
<% } %>

<% if (shipment) { %>
  <div class="card status-<%= shipment.status.toLowerCase().replace(/\s+/g,'-') %>">
    <div class="receipt-print-header">
      <div class="logo"><span class="logo-mark"></span>PIXEL WAVE <em>LOGISTICS</em></div>
      <p>Shipment Receipt &middot; Generated <%= new Date().toLocaleString() %></p>
    </div>
    <div class="card-head">
      <div>
        <div class="tn"><%= shipment.tracking_number %></div>
        <div class="route"><%= shipment.origin %> &rarr; <%= shipment.destination %></div>
      </div>
      <span class="pill <%= shipment.status.toLowerCase().replace(/\s+/g,'-') %>"><%= shipment.status %></span>
    </div>
    <div class="meta-grid">
      <div><span>Sender</span><%= shipment.sender_name %></div>
      <div><span>Receiver</span><%= shipment.receiver_name %></div>
      <div><span>Service</span><%= shipment.service || '—' %></div>
      <div><span>Weight</span><%= shipment.weight ? shipment.weight + ' kg' : '—' %></div>
      <div><span>Est. delivery</span><%= shipment.eta || '—' %></div>
    </div>
<div class="receipt-print-parties">
      <div>
        <h4>Ship From</h4>
        <p><%= shipment.sender_name %></p>
        <% if (shipment.sender_email) { %><p><%= shipment.sender_email %></p><% } %>
        <p><%= shipment.origin %></p>
      </div>
      <div>
        <h4>Ship To</h4>
        <p><%= shipment.receiver_name %></p>
        <% if (shipment.receiver_email) { %><p><%= shipment.receiver_email %></p><% } %>
        <p><%= shipment.destination %></p>
      </div>
    </div>

    <div class="receipt-print-package">
      <div><span>Service</span><%= shipment.service || 'Standard' %></div>
      <div><span>Weight</span><%= shipment.weight ? shipment.weight + ' kg' : '—' %></div>
      <div><span>Est. Delivery</span><%= shipment.eta || '—' %></div>
      <div class="full"><span>Package Description</span><%= shipment.notes || 'General cargo' %></div>
    </div>

    <div class="receipt-print-status">
      <div><span>Current Status</span><b><%= shipment.status %></b></div>
      <div><span>Current Location</span><b><%= events[0].location %></b></div>
    </div>
    <div class="map-section">
      <h3>Current Location</h3>
      <div id="live-map"></div>
      <div id="map-status" class="map-status"></div>
    </div>

    <div class="timeline">
      <h3>Shipment history</h3>
      <% events.forEach((h, i) => { %>
        <div class="tl-item <%= i === 0 ? '' : 'old' %>">
          <div class="tl-dot"></div>
          <div class="tl-body">
            <b><%= h.status %></b>
            <div class="tl-meta"><%= new Date(h.created_at).toLocaleString() %> &middot; <%= h.location %></div>
            <% if (h.note) { %><div class="tl-note"><%= h.note %></div><% } %>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="receipt-print-footer">
      <p>Thank you for shipping with Pixel Wave Logistics.</p>
      <p class="receipt-footer-meta">Questions about this shipment? support@pixelwavelogistics.com</p>
    </div>

    <div class="receipt-actions">
      <button class="btn small" onclick="window.print()">Print / Save Receipt</button>
    </div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
  (function(){
    const city = <%- JSON.stringify(events[0].location || '') %>;
    const statusEl = document.getElementById('map-status');
    if(!city){ statusEl.textContent = 'No location on file for this shipment yet.'; return; }
    statusEl.textContent = 'Locating ' + city + '…';
    fetch('https://nominatim.openstreetmap.org/search?format=json&limit=1&q=' + encodeURIComponent(city))
      .then(function(r){ return r.json(); })
      .then(function(results){
        if(!results || !results.length){
          statusEl.textContent = "Couldn't pin \"" + city + "\" on the map.";
          return;
        }
        const lat = parseFloat(results[0].lat);
        const lon = parseFloat(results[0].lon);
        statusEl.textContent = '';
        const map = L.map('live-map').setView([lat, lon], 6);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);
        L.marker([lat, lon]).addTo(map).bindPopup(city).openPopup();
      })
      .catch(function(){ statusEl.textContent = 'Map failed to load.'; });
  })();
  </script>
<% } %>

<%- include('partials/footer') %>
